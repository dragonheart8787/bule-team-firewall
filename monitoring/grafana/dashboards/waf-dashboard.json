{
  "dashboard": {
    "id": null,
    "title": "WAF \u4f01\u696d\u7d1a\u76e3\u63a7\u5100\u8868\u677f",
    "tags": [
      "waf",
      "security",
      "enterprise"
    ],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "WAF \u8acb\u6c42\u8655\u7406\u91cf",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(waf_requests_total[5m])",
            "legendFormat": "{{instance}}"
          }
        ],
        "yAxes": [
          {
            "label": "\u8acb\u6c42/\u79d2",
            "min": 0
          }
        ]
      },
      {
        "id": 2,
        "title": "WAF \u963b\u64cb\u7387",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(waf_blocked_requests_total[5m]) / rate(waf_requests_total[5m]) * 100",
            "legendFormat": "\u963b\u64cb\u7387 %"
          }
        ]
      },
      {
        "id": 3,
        "title": "SIEM \u8b66\u5831\u6578\u91cf",
        "type": "graph",
        "targets": [
          {
            "expr": "siem_total_alerts",
            "legendFormat": "\u7e3d\u8b66\u5831\u6578"
          }
        ]
      },
      {
        "id": 4,
        "title": "\u7cfb\u7d71\u5065\u5eb7\u72c0\u614b",
        "type": "table",
        "targets": [
          {
            "expr": "up",
            "legendFormat": "{{job}} - {{instance}}"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "5s"
  }
}